# Normalise line endings to LF in the repo; checkout converts to OS native.
* text=auto

# Force LF for shell/text files regardless of OS
*.py    text eol=lf
*.js    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.env   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary — never touch line endings
*.webp  binary
*.png   binary
*.jpg   binary
*.ico   binary
*.db    binary
