# CarbonTread — Local Environment Configuration Template
# Rename this file to .env and fill in the values below.

# Flask secret key for cookie signing and secure session management
SECRET_KEY=your_flask_secret_key_here

# Google Gemini API key (for structured event extraction and weekly narrative generation)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API key (for weather-aware recommendations)
# Register a key from: https://openweathermap.org/
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Gemini model identifier (default: gemini-3.1-flash-lite)
GEMINI_MODEL=gemini-3.1-flash-lite
